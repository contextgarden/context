<?xml version="1.0" encoding="UTF-8"?>

<?context-directive job ctxfile x-setups.ctx ?>

<cd:interface xmlns:cd="http://www.pragma-ade.com/commands">

    <cd:command name="checkdelimiters" level="system" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:content/>
        </cd:arguments>
    </cd:command>

    <cd:command name="fakeleftdelimiter" level="system" category="mathematics" file="math-del.mkxl"/>

    <cd:command name="fakerightdelimiter" level="system" category="mathematics" file="math-del.mkxl"/>

    <cd:command name="enabledelimiter" level="system" category="mathematics" file="math-del.mkxl"/>

    <cd:command name="disabledelimiter" level="system" category="mathematics" file="math-del.mkxl"/>

    <cd:command name="enablefiller" level="system" category="mathematics" file="math-del.mkxl"/>

    <cd:command name="disablefiller" level="system" category="mathematics" file="math-del.mkxl"/>

    <cd:command name="mathopnolimits" level="system" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:content/>
        </cd:arguments>
    </cd:command>

    <cd:command name="mathopdolimits" level="system" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:content/>
        </cd:arguments>
    </cd:command>

    <cd:command name="definemathdelimiter" level="style" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:resolve name="keyword-name"/>
            <cd:resolve name="keyword-name-optional"/>
            <cd:assignments list="yes" optional="yes">
                <cd:inherit name="setupmathdelimiters"/>
            </cd:assignments>
        </cd:arguments>
    </cd:command>

    <!--

        <cd:command name="setupmathdelimiter" level="style" category="mathematics" file="math-del.mkxl">
            <cd:arguments>
                <cd:resolve name="keyword-name-list-optional"/>
                <cd:assignments list="yes">
                    <cd:inherit name="setupmathdelimiters"/>
                </cd:assignments>
            </cd:arguments>
        </cd:command>

    -->

    <cd:command name="setupmathdelimiter" level="style" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:resolve name="keyword-name-list-optional"/>
            <cd:assignments list="yes">
                <cd:parameter name="define">
                    <cd:constant type="yes" default="yes"/>
                    <cd:constant type="no"/>
                </cd:parameter>
                <cd:parameter name="factor">
                    <cd:constant type="cd:number"/>
                </cd:parameter>
                <cd:parameter name="leftoffset">
                    <cd:constant type="cd:dimension"/>
                </cd:parameter>
                <cd:parameter name="rightoffset">
                    <cd:constant type="cd:dimension"/>
                </cd:parameter>
                <cd:parameter name="exact">
                    <cd:constant type="yes"/>
                    <cd:constant type="no" default="yes"/>
                </cd:parameter>
                <cd:parameter name="axis">
                    <cd:constant type="yes" default="yes"/>
                    <cd:constant type="no"/>
                </cd:parameter>
                <cd:parameter name="height">
                    <cd:constant type="cd:dimension"/>
                </cd:parameter>
                <cd:parameter name="depth">
                    <cd:constant type="cd:dimension"/>
                </cd:parameter>
                <cd:parameter name="symbol">
                    <cd:constant type="cd:number"/>
                </cd:parameter>
            </cd:assignments>
        </cd:arguments>
    </cd:command>

    <cd:command name="mathdelimiter" level="document" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:resolve name="keyword-name"/>
            <cd:resolve name="keyword-number-optional"/>
        </cd:arguments>
    </cd:command>

    <cd:command name="mathdelimiter" variant="assignment" level="document" category="mathematics" file="math-del.mkxl">
        <cd:arguments>
            <cd:resolve name="keyword-name"/>
            <cd:assignments list="yes" optional="yes">
                <cd:inherit name="setupmathdelimiters"/>
            </cd:assignments>
        </cd:arguments>
    </cd:command>

    <cd:command name="mathdelimiter" generated="yes" variant="example" level="document" category="mathematics" file="math-del.mkxl">
        <cd:sequence>
            <cd:string value="mathdelimiter"/>
        </cd:sequence>
        <cd:arguments>
            <cd:resolve name="keyword-number-optional"/>
        </cd:arguments>
    </cd:command>

    <cd:command name="mathdelimiter" generated="yes" variant="example:assignment" level="document" category="mathematics" file="math-del.mkxl">
        <cd:sequence>
            <cd:string value="mathdelimiter"/>
        </cd:sequence>
        <cd:arguments>
            <cd:assignments list="yes" optional="yes">
                <cd:inherit name="setupmathdelimiters"/>
            </cd:assignments>
        </cd:arguments>
    </cd:command>

</cd:interface>
