--             local z = %code%
--             local nx, ny, nz = normalize(-(%dfdx%),-(%dfdy%),1)
--             return z, nx, ny, nz
--         end
--     ]]

--     local combinedp = replacer [[
--         local function f(x,y)
--             return %code%
--         end
--         return function(x,y,dx,dy)
--             local z  = %code% -- f(x,y)
