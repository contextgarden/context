local normal_smooth <const> = 0
local normal_flat   <const> = 1
local normal_up     <const> = 2

local function validnormal(mode)
    if mode == "flat" then
        return normal_flat
    elseif mode == "up" then
        return normal_up
    else
        return normal_smooth
    end
end

