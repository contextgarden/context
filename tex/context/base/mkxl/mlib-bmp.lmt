--         local bsource = tonumber(p.source)
--         local btarget = tonumber(p.target)
--         if bsource and btarget then
--             local filter  = p.filter
--             if type(filter) == "string" then
--                 -- split and in sequence
--                 filter = metapost.filter(filter)
--             end
--             if type(filter) == "table" then
--                 local factor  = tonumber(p.factor)  or filter.factor  or 1
--                 local default = tonumber(p.default) or filter.default or 25
--                 local crop    = p.crop
--                 local mapping = filter.mapping or filter
--                 local source  = getbytemapdirect(bsource)
--                 local nx, ny, nz = bytemap.dimensions(source)
--                 local target = bytemap.new(nx,ny,nz)
--                 bytemap.filter(source,target,mapping,factor,default)
--                 if crop then
--                     local final = bytemap.new(nx-2,ny-2,nz)
--                     bytemap.overlay(target,final,1,1,0,0,nx-2,ny-2)
--                     target = final
--                 end
--                 mp.newbytemap(btarget,target)
--             end
--         end
--     end

    function mp.lmt_bytemap_filter()
        local p       = getparameterset("filter")
        local bsource = tonumber(p.source)
        local btarget = tonumber(p.target)
        if bsource and btarget then
            local filter  = p.filter
            local filters = false
            if type(filter) == "string" then
                filters = { }
                for s in gmatch(filter,"([^%s,]+)") do
                    filters[#filters+1] = metapost.filter(s)
                end
            elseif type(filter) == "table" then
                filters = { filter }
            else
                return
            end
            starttiming("bmp",true)
            local crop       = false
            local source     = getbytemapdirect(bsource)
            local nx, ny, nz = bytemap.dimensions(source)
            local target     = false
            for i=1,#filters do
                local filter  = filters[i]
                local factor  = tonumber(p.factor)  or filter.factor  or 1
                local default = tonumber(p.default) or filter.default or 25
                local mapping = filter.mapping or filter
                target = bytemap.new(nx,ny,nz)
                bytemap.filter(source,target,mapping,factor,default)
                source = target
                crop   = crop or p.clip
            end
            if crop == true then
                crop = 2
            else
                crop = tonumber(crop)
            end
            if crop then
                local final = bytemap.new(nx-2,ny-2,nz)
                bytemap.overlay(target,final,1,1,0,0,nx-2,ny-2)
                target = final
            end
            stoptiming("bmp")
            report("filtering %i to %i, runtime %s",bsource,btarget,elapsedtime("bmp"))
            mp.newbytemap(btarget,target)
        end
    end

end
