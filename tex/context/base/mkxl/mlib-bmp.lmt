do -- https://en.wikipedia.org/wiki/Kernel_(image_processing)

    -- shapening

    metapost.registerfilter {
        name    = "sharpen:5",
        default = 45,
        mapping = {
            { -3, -2,   -2, -2, -3 },
            { -2, -1,   -1, -1, -2 },
            { -2, -1, true, -1, -2 },
            { -2, -1,   -1, -1, -2 },
            { -3, -2,   -2, -2, -3 },
        }
    }

    metapost.registerfilter {
        name    = "sharpen:3:9",
        default = 9,
        mapping = {
            { -1,   -1, -1 },
            { -1, true, -1 },
            { -1,   -1, -1 },
        }
    }

    metapost.registerfilter {
        name    = "sharpen:3:5",
        default = 5,
        mapping = {
            {  0,   -1,  0 },
            { -1, true, -1 },
            {  0,   -1,  0 },
        }
    }

    metapost.registerfilter("sharpen:3","sharpen:3:9")

    -- edging

    metapost.registerfilter {
        name    = "edge:3:8",
        default = 8,
        mapping = {
            { -1,   -1, -1 },
            { -1, true, -1 },
            { -1,   -1, -1 },
        },
    }

    metapost.registerfilter {
        name    = "edge:3:4",
        default = 4,
     -- factor  = -1, -- try this
        mapping = {
            {  0,   -1,  0 },
            { -1, true, -1 },
            {  0,   -1,  0 },
        },
    }

    metapost.registerfilter {
        name    = "sobel:horizontal",
        default = 0,
        mapping = {
            { -1,   -2, -1 },
            {  0, true,  0 },
            {  1,    2,  1 },
        },
    }

    metapost.registerfilter {
        name    = "sharr:horizontal",
        default = 0,
        mapping = {
            { -3,  -10, -3 },
            {  0, true,  0 },
            {  3,   10,  3 },
        },
    }

    metapost.registerfilter {
        name    = "sobel:vertical",
        default = 0,
        mapping = {
            { -1,   -0, 1 },
            { -2, true, 2 },
            { -1,    0, 1 },
        },
    }

    metapost.registerfilter {
        name    = "edge:horizontal",
        default = 3,
        mapping = {
            {  0,    0,  0 },
            { -1, true, -1 },
            {  0,    0,  0 },
        },
    }

    metapost.registerfilter {
        name    = "edge:vertical",
        default = 3,
        mapping = {
            { 0,   -1, 0 },
            { 0, true, 1 },
            { 0,   -1, 0 },
        },
    }

    metapost.registerfilter("edge:3","edge:3:8")

    -- embossing

    metapost.registerfilter {
        name    = "emboss:3",
        default = 1,
        mapping = {
            { -2, -1, 0 },
            { -1,  1, 1 },
            {  0,  1, 2 },
        },
    }

    -- blurring

    metapost.registerfilter {
        name    = "boxblur",
     -- normal  = 1/9,
        factor  = 1/9,
        mapping = {
            { 1, 1, 1 },
            { 1, 1, 1 },
            { 1, 1, 1 },
        },
    }

    metapost.registerfilter {
        name    = "gaussianblur:3",
     -- normal  = 1/16,
        factor  = 1/16,
        mapping = {
            { 1, 2, 1 },
            { 2, 4, 2 },
            { 1, 2, 1 },
        },
    }

    metapost.registerfilter {
        name    = "gaussianblur:5",
     -- normal  = 1/256,
        factor  = 1/256,
        mapping = {
            { 1,  4,  6,  4, 1 },
            { 4, 16, 24, 16, 1 },
            { 6,  4, 36,  4, 1 },
            { 4, 16, 24, 16, 1 },
            { 1,  4,  6,  4, 1 },
        },
    }

    metapost.registerfilter("gaussianblur","gaussianblur:5")

    -- unsharpening

    metapost.registerfilter {
        name    = "unsharp:5",
     -- normal  = -1/256,
        factor  = -1/256,
        mapping = {
            { 1,  4,    6,  4, 1 },
            { 4, 16,   24, 16, 1 },
            { 6,  4, -476,  4, 1 },
            { 4, 16,   24, 16, 1 },
            { 1,  4,    6,  4, 1 },
        },
    }

    --

